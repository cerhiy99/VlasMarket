{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler", // Змінено на bundler для кращої підтримки Next.js 15/16
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "app/*": ["app/*"], // Дозволяє писати import 'app/...' в TS файлах
      "@components/*": ["app/components/*"],
      "@utils/*": ["app/components/utils/*"],
      "@http": ["app/http/index.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": ["node"]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "app/**/*",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
